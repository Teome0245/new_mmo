package server.zone.managers.creature.observers;

import server.zone.objects.creature.ai.AiAgent;
import server.zone.objects.scene.SceneObject;
import server.zone.objects.tangible.TangibleObject;
import engine.core.ManagedObject;
import engine.util.Observer;
import engine.util.Observable;
import system.thread.Mutex;

include engine.log.Logger;
include system.util.Vector;
include engine.util.u3d.Vector3;

class CreatureHerdObserver extends Observer implements Logger {
	@local
	@dereferenced
	protected Vector<AiAgent> herdMembers;

	@dereferenced
	protected transient Mutex herdLock;

	// Spacing configuration
	protected float spacingBuffer;
	protected float maxJitterPercent;

	public CreatureHerdObserver() {
		super();

		Logger.setLoggingName("CreatureHerdObserver");

		// Default spacing: 4x creature diameter, 10% jitter
		spacingBuffer = 4.0f;
		maxJitterPercent = 0.1f;
	}

	@preLocked
	public void setSpacingBuffer(float buffer) {
		spacingBuffer = buffer;
	}

	@read
	public float getSpacingBuffer() {
		return spacingBuffer;
	}

	@preLocked
	public void setMaxJitterPercent(float jitter) {
		maxJitterPercent = jitter;
	}

	@read
	public float getMaxJitterPercent() {
		return maxJitterPercent;
	}

	@local
	@read
	public int size() {
		return herdMembers.size();
	}

	@local
	@preLocked
	public native void removeMember(int index) {
		herdMembers.remove(index);
	}

	@local
	public native void removeMember(AiAgent member);

	@local
	public native void addMember(AiAgent member);

	@local
	public native AiAgent getMember(int teamMemberIndex);

	@local
	public native int getMemberPosition(unsigned long memberID);

	@local
	public native AiAgent getHerdLeader();

	@local
	public native void despawnHerd();

	/**
	 * Make all herd members rest (sit or lie down)
	 * Skips null, dead, or in-combat members
	 * @return true if any members started resting
	 */
	@local
	public native boolean restHerd();

	/**
	 * Wake all herd members from resting state
	 * Sets posture to UPRIGHT and movement state to PATROLLING
	 * @return true if any members were woken
	 */
	@local
	public native boolean stopHerdRest();

	/**
	 * Calculate the local formation offset for a given position index
	 * @param positionIndex The member's position in the herd (0 = leader)
	 * @param followerRadius The template radius of the follower
	 * @param leaderRadius The template radius of the leader
	 * @return Vector3 local offset relative to leader (unrotated)
	 */
	@local
	@dereferenced
	public native Vector3 getFormationOffset(int positionIndex, float followerRadius, float leaderRadius);

	/**
	 * Calculate the world position a herd member should move to
	 * Dynamically calculates based on member's current position in herd
	 * @param member The AiAgent requesting its formation position
	 * @return Vector3 world position for the member's formation slot
	 */
	@local
	@dereferenced
	public native Vector3 getFormationWorldPosition(AiAgent member);
}
